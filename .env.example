# ─── Variables de entorno snow_alert ─────────────────────────────────────────
# Copia este archivo como .env y completa los valores.
# NUNCA subas .env al repositorio (ya está en .gitignore).

# ── Databricks AI Gateway (modelo gratuito — uso general) ──────────────────
DATABRICKS_TOKEN=dapi...              # Token personal Databricks (regenerar si fue expuesto)
# DATABRICKS_SECRET_NAME=projects/<proyecto>/secrets/databricks-token/versions/latest
#   Ruta en Secret Manager usada si DATABRICKS_TOKEN no está definido
#   (default: se construye con GOOGLE_CLOUD_PROJECT)
DATABRICKS_BASE_URL=https://dbc-6f162706-efdf.cloud.databricks.com/ai-gateway/mlflow/v1
DATABRICKS_MODEL=qwen3-next-80b-a3b-instruct

# ── Anthropic / Claude (pago — reservado para validación final) ─────────────
ANTHROPIC_API_KEY=sk-ant-...          # Solo cargar cuando tengas saldo para las pruebas finales

# ── Google Cloud Platform ───────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=climas-chileno
# Auth: ejecutar gcloud auth application-default login

# ── Gemini Pro (Vertex AI — proyecto AI-Models) ──────────────────────────────
GEMINI_GCP_PROJECT=project-c742757f-1731-44cd-a40   # proyecto AI-Models (ya es el default)
GEMINI_GCP_LOCATION=global
GEMINI_MODEL=gemini-3.1-pro-preview
# Activa Gemini en todos los subagentes sin tocar cada agente.py:
# SUBAGENTES_PROVEEDOR=gemini3
# Nivel de thinking de Gemini 3.x: LOW (default) | MEDIUM (~4k tokens) | HIGH (~8k tokens)
# GEMINI_THINKING_LEVEL=MEDIUM

# ── WeatherNext 2 (pronóstico ensemble GCP — requerido para PINN y niveles ≥3) ─
USE_WEATHERNEXT2=true               # SIEMPRE true en producción y simulaciones locales

# ── Modo proveedor por defecto (databricks | anthropic | gemini3) ────────────
# Sin SUBAGENTES_PROVEEDOR cada subagente usa su atributo de clase PROVEEDOR.
# LLM_PROVEEDOR_DEFAULT=databricks
